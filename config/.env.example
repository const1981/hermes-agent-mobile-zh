# ============================================================
#  Hermes 密钥样例（.env）
#  写入位置：~/.hermes/.env
#  权限建议 600（chmod 600 ~/.hermes/.env），不要提交到任何仓库。
#  config.yaml 通过 ${变量名} 引用这里的变量。
# ============================================================

# 只保留你实际使用的那一个（与 config.yaml 的 provider 对应）

# 方案 A：OpenRouter
OPENROUTER_API_KEY=sk-or-xxxxxx

# 方案 B：智谱 GLM
# ZHIPU_API_KEY=你的智谱Key

# 方案 C：DeepSeek
# DEEPSEEK_API_KEY=你的DeepSeekKey

# 方案 D：Kimi
# KIMI_API_KEY=你的KimiKey

# 方案 E：自定义端点
# OPENAI_API_KEY=你的自定义Key

# 可选：Telegram 网关（不用的话留空或删掉）
# TELEGRAM_BOT_TOKEN=123456789:AAxxxxxx
